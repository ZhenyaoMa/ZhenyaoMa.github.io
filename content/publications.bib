@article{zhenyao2026behavior,
selected    = {true},
title={Behavior Learning (BL)},
author={Zhenyao Ma and Yue Liang and Dongxu Li},
booktitle={International Conference on Learning Representations (ICLR)},
year={2026},
url={https://openreview.net/forum?id=bbAN9PPcI1},
description = {Inspired by behavioral science, we propose Behavior Learning (BL), a novel general-purpose ML framework that learns (hierarchical) optimization structures from data, as a promising alternative to Multi-Layer Perceptrons (MLPs) for scientific domains involving optimization.},
abstract = {Inspired by behavioral science, we propose Behavior Learning (BL), a novel general-purpose machine learning framework that learns interpretable and identifiable optimization structures from data, ranging from single optimization problems to hierarchical compositions. It unifies predictive performance, intrinsic interpretability, and identifiability, with broad applicability to scientific domains involving optimization. BL parameterizes a compositional utility function built from intrinsically interpretable modular blocks, which induces a data distribution for prediction and generation. Each block represents and can be written in symbolic form as a utility maximization problem (UMP), a foundational paradigm in behavioral science and a universal framework of optimization. BL supports architectures ranging from a single UMP to hierarchical compositions, the latter modeling hierarchical optimization structures. Its smooth and monotone variant (IBL) guarantees identifiability. Theoretically, we establish the universal approximation property of BL, and analyze the M-estimation properties of IBL. Empirically, BL demonstrates strong predictive performance, intrinsic interpretability and scalability to high-dimensional data.}
}

@article{MSG2026SocialPreferencesComplexity,
  selected    = {true},
  title       = {Human Social Preferences in Simple and Complex Decisions},
  author      = {{With Sen Geng and Menglong Guan}},
  year        = {2026},
  journal = {Working Paper},
  description = {Social preferences capture human motives beyond self-interest, such as kindness and moral concern. In this, we study how complexity endogenously affects social preferences.},
  abstract = {We develop a rational-choice framework that can explain why behavior might appear selfish in some contexts while pro-social in others, even if the underlying social preferences themselves are stable. Our model characterizes that expression of social preferences (active social consideration) is endogenous to the complexity of the decision problem. We design experiments to test the theory.}
}
